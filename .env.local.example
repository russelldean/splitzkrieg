# Azure SQL (used at build time and revalidation only — visitors never hit the DB)
AZURE_SQL_SERVER=splitzkrieg-sql.database.windows.net
AZURE_SQL_DATABASE=splitzkrieg
AZURE_SQL_USER=
AZURE_SQL_PASSWORD=

# Revalidation (protect the /api/revalidate endpoint)
# Generate with: openssl rand -hex 32
REVALIDATION_SECRET=

# Resend (email notifications for feedback submissions)
RESEND_API_KEY=

# Public site URL (used for OG meta tags and share links)
NEXT_PUBLIC_SITE_URL=https://splitzkrieg.org
